{
  "$schema": "https://raw.githubusercontent.com/nicklasaven/tauri/dev/core/tauri-config-schema/schema.json",
  "productName": "EXIF Batch Editor",
  "version": "0.1.0",
  "identifier": "com.merseong.exif-batch-editor",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "title": "EXIF Batch Editor",
    "windows": [
      {
        "title": "EXIF Batch Editor",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
